<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ContextMenu?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #111C22; -fx-font-family: 'Segoe UI', Arial, sans-serif;" stylesheets="@global.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.gruppo04.view.PlaylistDetailViewController">

    <!-- INTESTAZIONE — nome playlist + info -->
    <top>
        <VBox spacing="6">
            <padding><Insets bottom="12" left="20" right="20" top="20" /></padding>
           <children>
   
               <Label fx:id="labelNamePlaylist" style="-fx-text-fill: #E8EDF0; -fx-font-size: 22px; -fx-font-weight: bold;" text="Nome Playlist" />
   
               <HBox alignment="CENTER_LEFT" spacing="12">
      <children>
                      <Label fx:id="labelNumTracks" style="-fx-text-fill: #5C7A7D; -fx-font-size: 12px;" text="0 tracce" />
                      <Label style="-fx-text-fill: #5C7A7D; -fx-font-size: 12px;" text="·" />
                      <Label fx:id="labelTotalDuration" style="-fx-text-fill: #5C7A7D; -fx-font-size: 12px;" text="0 min" />
      </children>
               </HBox>
   
               <!-- Bottoni azione playlist -->
               <HBox alignment="CENTER_LEFT" spacing="10">
                   <padding>
                  <Insets top="6" />
               </padding>
      <children>
                      <Button fx:id="btnAddTrack" onAction="#handleAddTrack" style="-fx-background-color: #1D6A72;                                -fx-text-fill: #FFFFFF;                                -fx-font-weight: bold;                                -fx-font-size: 13px;                                -fx-background-radius: 7;                                -fx-padding: 8 18 8 18;                                -fx-cursor: hand;" text="+ Aggiungi Track" />
                      <Button fx:id="btnRemoveTrack" disable="true" onAction="#handleRemoveTrack" style="-fx-background-color: #1B2A2F;                                -fx-text-fill: #E8EDF0;                                -fx-font-size: 13px;                                -fx-background-radius: 7;                                -fx-border-color: #2C3E40;                                -fx-border-radius: 7;                                -fx-border-width: 1;                                -fx-padding: 8 18 8 18;                                -fx-cursor: hand;" text="Rimuovi Track" />
                  <Button fx:id="undoBtn" mnemonicParsing="false" onAction="#handleUndo" text="Undo" styleClass="undo-button"/>
          <Region HBox.hgrow="ALWAYS" />
          <Button fx:id="btnPlay" onAction="#handlePlay" style="-fx-background-color: #1D6A72;            -fx-text-fill: #FFFFFF;            -fx-font-weight: bold;            -fx-font-size: 13px;            -fx-background-radius: 7;            -fx-padding: 8 18 8 18;            -fx-cursor: hand;" text="▶ Play All" />

      </children>
               </HBox>
           </children>
        </VBox>
    </top>

    <!-- TABELLA TRACCE -->
    <center>
        <VBox>
            <padding><Insets bottom="20" left="20" right="20" top="8" /></padding>
           <children>

               <TableView fx:id="tableTracks" style="-fx-background-color: transparent;                   -fx-table-cell-border-color: transparent;                   -fx-table-header-border-color: transparent;                   -fx-border-color: transparent;                   -fx-control-inner-background: transparent;                   -fx-padding: 0;" VBox.vgrow="ALWAYS">
                   <contextMenu>
                       <ContextMenu style="-fx-background-color: #1B2A2F;                         -fx-background-radius: 8;                         -fx-border-color: #2C3E40;                         -fx-border-radius: 8;                         -fx-border-width: 1;                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 12, 0, 0, 4);                         -fx-padding: 4 0 4 0;">
                           <items>
                               <MenuItem onAction="#handlePlayTrack" style="-fx-text-fill: #E8EDF0;" text="▶   Riproduci ora" />
                               <MenuItem onAction="#handleRemoveTrack" style="-fx-text-fill: #E05555;" text="✕   Rimuovi dalla playlist" />
                           </items>
                       </ContextMenu>
                   </contextMenu>
                   <columns>
                       <TableColumn fx:id="colTitle" prefWidth="220" text="TITOLO" />
                       <TableColumn fx:id="colAuthor" prefWidth="160" text="AUTORE" />
                       <TableColumn fx:id="colYear" prefWidth="70" style="-fx-alignment: CENTER_RIGHT;" text="ANNO" />
                       <TableColumn fx:id="colGenre" prefWidth="120" text="GENERE" />
                       <TableColumn fx:id="colDuration" prefWidth="80" style="-fx-alignment: CENTER_RIGHT;" text="DURATA" />
                   </columns>
   
                   <placeholder>
                       <VBox alignment="CENTER" spacing="8">
                          <children>
                              <Label fx:id="labelEmptyPlaylist" style="-fx-text-fill: #3A5258; -fx-font-size: 15px; -fx-font-weight: bold;" text="Nessuna traccia nella playlist" />
                              <Label style="-fx-text-fill: #2C3E40; -fx-font-size: 12px;" text="Aggiungi tracce con il pulsante in alto" />
                          </children>
                       </VBox>
                   </placeholder>
   
               </TableView>
           </children>
        </VBox>
    </center>

</BorderPane>
