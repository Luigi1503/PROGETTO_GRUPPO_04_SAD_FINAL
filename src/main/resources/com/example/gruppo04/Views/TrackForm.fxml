<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.gruppo04.view.TrackFormViewController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label text="Gestione Traccia" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                <GridPane hgap="10.0" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="80.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Titolo:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="titleField" promptText="Inserisci il titolo..." GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="Autore:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="authorField" promptText="Inserisci l'autore..." GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Genere:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <ComboBox fx:id="genreComboBox" prefWidth="250.0" promptText="Seleziona genere" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="Anno:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <Spinner fx:id="yearSpinner" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label text="Durata (s):" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <Spinner fx:id="durationSpinner" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    </children>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button fx:id="addButton" text="Aggiungi" onAction="#handleAddAction" />
                        <Button fx:id="updateButton" text="Salva Modifiche" onAction="#handleUpdateAction" disable="true" />
                        <Button fx:id="deleteButton" text="Elimina" onAction="#handleDeleteAction" disable="true" style="-fx-text-fill: red;" />
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>