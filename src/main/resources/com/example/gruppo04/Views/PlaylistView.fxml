<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<BorderPane prefHeight="400.0" prefWidth="600.0" styleClass="playlist-panel" stylesheets="@playlist.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.gruppo04.view.PlaylistViewController">

   <top>
      <HBox alignment="CENTER_LEFT" spacing="10">
         <padding><Insets bottom="12" left="24" right="24" top="20" /></padding>
         <children>
            <Button fx:id="undoBtn" mnemonicParsing="false" onAction="#handleUndo" prefHeight="26.0" prefWidth="53.0" text="Undo" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnPlayAll" onAction="#handlePlayAll" styleClass="play-all-btn" text="▶ Play All" />
         </children>
      </HBox>
   </top>

   <center>
      <ScrollPane fitToWidth="true" BorderPane.alignment="CENTER">
         <content>
            <FlowPane fx:id="playlistGrid" />
         </content>
      </ScrollPane>
   </center>
</BorderPane>
