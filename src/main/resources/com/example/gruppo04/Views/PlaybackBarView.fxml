<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import java.lang.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox alignment="CENTER" prefHeight="80.0" prefWidth="1100.0" style="-fx-background-color: #0D1519;              -fx-border-color: #1B2A2F;              -fx-border-width: 1 0 0 0;              -fx-font-family: 'Segoe UI', Arial, sans-serif;" stylesheets="@PlaybackBarView.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.gruppo04.view.PlaybackBarViewController">

    <padding><Insets bottom="0" left="24" right="24" top="0" /></padding>
   <children>
   
       <!-- ══════════════════════════════════════
            SINISTRA — info traccia corrente
            ══════════════════════════════════════ -->
       <HBox alignment="CENTER_LEFT" minWidth="280.0" prefWidth="280.0" spacing="14">
      <children>
      
              <!-- Icona traccia -->
              <StackPane prefHeight="48.0" prefWidth="48.0" style="-fx-background-color: #1B2A2F;                           -fx-background-radius: 8;">
         <children>
                     <Label style="-fx-text-fill: #1D9E75;                           -fx-font-size: 20px;" text="♪" />
         </children>
              </StackPane>
      
              <!-- Titolo traccia + artista · anno · genere -->
              <VBox alignment="CENTER_LEFT" spacing="4">
         <children>
         
                     <Label fx:id="labelTrackTitle" style="-fx-text-fill: #E8EDF0;                           -fx-font-size: 13px;                           -fx-font-weight: bold;" text="Nessuna traccia" />
         
                     <HBox alignment="CENTER_LEFT" spacing="4">
            <children>
                            <Label fx:id="labelTrackArtist" style="-fx-text-fill: #5C7A7D;                               -fx-font-size: 11px;" text="—" />
                            <Label style="-fx-text-fill: #5C7A7D;                               -fx-font-size: 11px;" text="·" />
                            <Label fx:id="labelTrackYear" style="-fx-text-fill: #5C7A7D;                               -fx-font-size: 11px;" text="—" />
                            <Label style="-fx-text-fill: #5C7A7D;                               -fx-font-size: 11px;" text="·" />
                            <Label fx:id="labelTrackGenre" style="-fx-text-fill: #5C7A7D;                               -fx-font-size: 11px;" text="—" />
            </children>
                     </HBox>
         </children>
      
              </VBox>
      </children>

   
       </HBox>
   
       <!-- ══════════════════════════════════════
            CENTRO — controlli + barra avanzamento
            ══════════════════════════════════════ -->
       <VBox alignment="CENTER" spacing="8.0" HBox.hgrow="ALWAYS">
      <children>
      
              <!-- Bottoni controllo -->
              <HBox alignment="CENTER" spacing="12.0">
         <children>
         
                     <!-- Skip precedente -->
                     <Button onAction="#handlePrevious" style="-fx-background-color: transparent;                            -fx-text-fill: #9FB2B8;                            -fx-font-size: 16px;                            -fx-cursor: hand;                            -fx-padding: 4;" text="⏮">
                         <tooltip>
                        <Tooltip text="Traccia precedente" />
                     </tooltip>
                     </Button>
         
                     <!-- Play / Pausa -->
                     <Button fx:id="btnPlayPause" onAction="#handlePlayPause" style="-fx-background-color: #1D9E75;                            -fx-text-fill: #FFFFFF;                            -fx-font-size: 14px;                            -fx-background-radius: 50;                            -fx-min-width: 36; -fx-min-height: 36;                            -fx-max-width: 36; -fx-max-height: 36;                            -fx-cursor: hand;                            -fx-padding: 0;" text="▶" />
         
                     <!-- Skip traccia successiva -->
                     <Button onAction="#handleSkipTrack" style="-fx-background-color: transparent;                            -fx-text-fill: #9FB2B8;                            -fx-font-size: 16px;                            -fx-cursor: hand;                            -fx-padding: 4;" text="⏭">
                         <tooltip>
                        <Tooltip text="Traccia successiva" />
                     </tooltip>
                     </Button>
         
                     <!-- Skip playlist successiva — visibile solo durante riproduzione playlist -->
                     <Button fx:id="btnSkipPlaylist" managed="false" onAction="#handleSkipPlaylist" style="-fx-background-color: transparent;                            -fx-text-fill: #9FB2B8;                            -fx-font-size: 12px;                            -fx-cursor: hand;                            -fx-padding: 4;" text="⏭⏭" visible="false">
                         <tooltip>
                        <Tooltip text="Playlist successiva" />
                     </tooltip>
                     </Button>
         </children>
      
              </HBox>
      
              <!-- Barra avanzamento + tempo -->
              <HBox alignment="CENTER" spacing="10.0">
         <children>
         
                     <Label fx:id="labelCurrentTime" style="-fx-text-fill: #5C7A7D; -fx-font-size: 11px;" text="0:00" />
         
                     <ProgressBar fx:id="progressBar" prefHeight="4.0" prefWidth="300.0" progress="0.0" style="-fx-accent: #1D9E75;                                 -fx-background-color: #2C3E40;                                 -fx-background-radius: 4;" />
         
                     <Label fx:id="labelTotalTime" style="-fx-text-fill: #5C7A7D; -fx-font-size: 11px;" text="0:00" />
         </children>
      
              </HBox>
      </children>
   
       </VBox>
   
       <!-- ══════════════════════════════════════
            DESTRA — modalità attiva (sola lettura, aggiornata da Observer)
            ══════════════════════════════════════ -->
       <HBox alignment="CENTER_RIGHT" minWidth="280.0" prefWidth="280.0" spacing="8">
           <children>
               <Button fx:id="btnSequential" onAction="#handleSequential" styleClass="mode-btn" text="→ Sequential" />
               <Button fx:id="btnShuffle" onAction="#handleShuffle" styleClass="mode-btn" text="⇄ Shuffle" />
               <Button fx:id="btnLoop" onAction="#handleLoop" styleClass="mode-btn" text="↺ Loop" />
           </children>
       </HBox>

   </children>

</HBox>
