<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gruppo04.view.MainViewController"
            prefWidth="1100.0" prefHeight="700.0"
            style="-fx-background-color: #111C22; -fx-font-family: 'Segoe UI', Arial, sans-serif;">

    <!-- ══════════════════════════════════════
         HEADER — titolo applicazione
         ══════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: #0D1519;
                     -fx-border-color: #1B2A2F;
                     -fx-border-width: 0 0 1 0;">
            <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
            <Label text="🎵 Music Playlist Manager"
                   style="-fx-text-fill: #E8EDF0;
                          -fx-font-size: 16px;
                          -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- ══════════════════════════════════════
         SIDEBAR SINISTRA
         ══════════════════════════════════════ -->
    <left>
        <VBox prefWidth="220"
              style="-fx-background-color: #0D1519;
                     -fx-border-color: #1B2A2F;
                     -fx-border-width: 0 1 0 0;">
            <padding><Insets top="24" right="0" bottom="24" left="0"/></padding>

            <!-- Titolo sezione -->
            <Label text="My Library"
                   style="-fx-text-fill: #5C7A7D;
                          -fx-font-size: 11px;
                          -fx-font-weight: bold;
                          -fx-padding: 0 20 8 20;"/>

            <Separator style="-fx-background-color: #1B2A2F;"/>

            <!-- Navigazione principale -->
            <VBox spacing="2">
                <padding><Insets top="12" bottom="12"/></padding>

                <Button fx:id="btnHome" text="🏠  Home"
                        maxWidth="Infinity"
                        onAction="#handleHome"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #E8EDF0;
                               -fx-font-size: 13px;
                               -fx-alignment: CENTER_LEFT;
                               -fx-padding: 10 20 10 20;
                               -fx-cursor: hand;"/>

                <Button fx:id="btnAllTracks" text="🎵  All Tracks"
                        maxWidth="Infinity"
                        onAction="#handleAllTracks"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #E8EDF0;
                               -fx-font-size: 13px;
                               -fx-alignment: CENTER_LEFT;
                               -fx-padding: 10 20 10 20;
                               -fx-cursor: hand;"/>

                <Button fx:id="btnPlaylists" text="📋  Playlists"
                        maxWidth="Infinity"
                        onAction="#handlePlaylists"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #E8EDF0;
                               -fx-font-size: 13px;
                               -fx-alignment: CENTER_LEFT;
                               -fx-padding: 10 20 10 20;
                               -fx-cursor: hand;"/>
            </VBox>

            <Separator style="-fx-background-color: #1B2A2F;"/>

            <!-- My Playlists -->
            <Label text="MY PLAYLISTS"
                   style="-fx-text-fill: #5C7A7D;
                          -fx-font-size: 11px;
                          -fx-font-weight: bold;
                          -fx-padding: 16 20 8 20;"/>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: #0D1519;
                   -fx-background: #0D1519;
                   -fx-border-color: transparent;">
                <VBox fx:id="sidebarPlaylistList" spacing="2">
                    <padding><Insets right="0" left="0"/></padding>
                </VBox>
            </ScrollPane>

        </VBox>
    </left>

    <!-- ══════════════════════════════════════
         AREA CENTRALE — pannelli intercambiabili
         ══════════════════════════════════════ -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color: #111C22;">
        </StackPane>
    </center>

</BorderPane>
