<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gruppo04.view.MainViewController"
            prefWidth="1100.0" prefHeight="700.0"
            style="-fx-background-color: #111C22; -fx-font-family: 'Segoe UI', Arial, sans-serif;">

    <!-- ══════════════════════════════════════
         HEADER — titolo applicazione
         ══════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: #0D1519;
                 -fx-border-color: #1B2A2F;
                 -fx-border-width: 0 0 1 0;">
            <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
            <Label text="Music Playlist Manager" graphicTextGap="10"
                   style="-fx-text-fill: #E8EDF0;
                      -fx-font-size: 16px;
                      -fx-font-weight: bold;">
                <graphic>
                    <FontIcon iconLiteral="mdi2m-music-circle" iconSize="20" iconColor="#1D9E75"/>
                </graphic>
            </Label>
            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Bottone help -->
            <Button fx:id="btnHelp" text="?" onAction="#handleHelp"
                    style="-fx-background-color: #1B2A2F;
                       -fx-text-fill: #E8EDF0;
                       -fx-font-size: 14px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 50%;
                       -fx-min-width: 30px;
                       -fx-min-height: 30px;
                       -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ══════════════════════════════════════
         SIDEBAR SINISTRA
         ══════════════════════════════════════ -->
    <left>
        <VBox prefWidth="220"
              style="-fx-background-color: #0D1519;
                     -fx-border-color: #1B2A2F;
                     -fx-border-width: 0 1 0 0;">
            <padding><Insets top="24" right="0" bottom="24" left="0"/></padding>

            <!-- Titolo sezione -->
            <Label text="My Library"
                   style="-fx-text-fill: #5C7A7D;
                          -fx-font-size: 11px;
                          -fx-font-weight: bold;
                          -fx-padding: 0 20 8 20;"/>

            <Separator style="-fx-background-color: #1B2A2F;"/>

            <!-- Navigazione principale -->
            <VBox spacing="2">
                <padding><Insets top="12" bottom="12"/></padding>

                <Button fx:id="btnHome" text="Home" graphicTextGap="14"
                        maxWidth="Infinity" onAction="#handleHome"
                        style="-fx-background-color: transparent; -fx-text-fill: #E8EDF0;
                   -fx-font-size: 13px; -fx-alignment: CENTER_LEFT;
                   -fx-padding: 10 20 10 20; -fx-cursor: hand;">
                    <graphic>
                        <FontIcon iconLiteral="mdi2h-home" iconSize="18" iconColor="#E8EDF0"/>
                    </graphic>
                </Button>

                <Button fx:id="btnAllTracks" text="All Tracks" graphicTextGap="14"
                        maxWidth="Infinity" onAction="#handleAllTracks"
                        style="-fx-background-color: transparent; -fx-text-fill: #E8EDF0;
                   -fx-font-size: 13px; -fx-alignment: CENTER_LEFT;
                   -fx-padding: 10 20 10 20; -fx-cursor: hand;">
                    <graphic>
                        <FontIcon iconLiteral="mdi2m-music" iconSize="18" iconColor="#E8EDF0"/>
                    </graphic>
                </Button>

                <Button fx:id="btnPlaylists" text="Playlists" graphicTextGap="14"
                        maxWidth="Infinity" onAction="#handlePlaylists"
                        style="-fx-background-color: transparent; -fx-text-fill: #E8EDF0;
                   -fx-font-size: 13px; -fx-alignment: CENTER_LEFT;
                   -fx-padding: 10 20 10 20; -fx-cursor: hand;">
                    <graphic>
                        <FontIcon iconLiteral="mdi2p-playlist-music" iconSize="18" iconColor="#E8EDF0"/>
                    </graphic>
                </Button>

                <Button fx:id="btnAutomaticPlaylists" text="Automatic Playlists" graphicTextGap="14"
                        maxWidth="Infinity" onAction="#handleAutomaticPlaylists"
                        style="-fx-background-color: transparent; -fx-text-fill: #E8EDF0;
                   -fx-font-size: 13px; -fx-alignment: CENTER_LEFT;
                   -fx-padding: 10 20 10 20; -fx-cursor: hand;">
                    <graphic>
                        <FontIcon iconLiteral="mdi2p-playlist-music" iconSize="18" iconColor="#E8EDF0"/>
                    </graphic>
                </Button>
            </VBox>

            <Separator style="-fx-background-color: #1B2A2F;"/>

            <!-- My Playlists -->
            <Label text="MY PLAYLISTS"
                   style="-fx-text-fill: #5C7A7D;
                          -fx-font-size: 11px;
                          -fx-font-weight: bold;
                          -fx-padding: 16 20 8 20;"/>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: #0D1519;
                   -fx-background: #0D1519;
                   -fx-border-color: transparent;
                   -fx-padding: 0;">
                <VBox fx:id="sidebarPlaylistList" spacing="2">
                    <padding><Insets right="0" left="0"/></padding>
                </VBox>
            </ScrollPane>


            <Label text="AUTOMATIC PLAYLISTS"
                   style="-fx-text-fill: #5C7A7D; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 16 20 8 20;"/>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: #0D1519;
                   -fx-background: #0D1519;
                   -fx-border-color: transparent;
                   -fx-padding: 0;">
            <VBox fx:id="sidebarAutoPlaylistList" spacing="2">
                <padding><Insets right="0" left="0"/></padding>
            </VBox>
        </ScrollPane>
        </VBox>
    </left>

    <!-- ══════════════════════════════════════
         AREA CENTRALE — pannelli intercambiabili
         ══════════════════════════════════════ -->
    <center>
        <StackPane>
            <StackPane fx:id="contentArea"
                       style="-fx-background-color: #111C22;"/>

            <!-- Pannello help — nascosto di default -->
            <VBox fx:id="helpBox" visible="false" managed="false"
                  alignment="TOP_CENTER"
                  style="-fx-background-color: #0D1519;
                     -fx-padding: 32;
                     -fx-border-color: #1B2A2F;
                     -fx-border-width: 1;">

                <Label text="Guida alle modalità di riproduzione"
                       style="-fx-text-fill: #1D9E75;
                          -fx-font-size: 15px;
                          -fx-font-weight: bold;
                          -fx-padding: 0 0 20 0;"/>

                <GridPane hgap="16" vgap="16">

                    <!-- ── Intestazioni colonne ── -->
                    <Label text=""
                           GridPane.columnIndex="0" GridPane.rowIndex="0"/>

                    <Label fx:id="lblSequential" text="▶  Sequential"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"
                           style="-fx-text-fill: #1D9E75; -fx-font-weight: bold; -fx-font-size: 13px;
                  -fx-background-color: transparent; -fx-padding: 6 12 6 12;
                  -fx-background-radius: 6;"/>

                    <Label fx:id="lblShuffle" text="⇄  Shuffle"
                           GridPane.columnIndex="2" GridPane.rowIndex="0"
                           style="-fx-text-fill: #1D9E75; -fx-font-weight: bold; -fx-font-size: 13px;
                  -fx-background-color: transparent; -fx-padding: 6 12 6 12;
                  -fx-background-radius: 6;"/>

                    <Label fx:id="lblLoop" text="↺  Loop"
                           GridPane.columnIndex="3" GridPane.rowIndex="0"
                           style="-fx-text-fill: #1D9E75; -fx-font-weight: bold; -fx-font-size: 13px;
                  -fx-background-color: transparent; -fx-padding: 6 12 6 12;
                  -fx-background-radius: 6;"/>

                    <!-- ── Riga Catalogo ── -->
                    <Label text="Catalogo"
                           GridPane.columnIndex="0" GridPane.rowIndex="1"
                           style="-fx-text-fill: #8AABAE; -fx-font-weight: bold; -fx-font-size: 12px;"/>

                    <VBox fx:id="cellCatalogSequential" spacing="6"
                          GridPane.columnIndex="1" GridPane.rowIndex="1"
                          style="-fx-background-color: #111C22; -fx-padding: 10; -fx-background-radius: 6;">
                        <Label text="⏭  →  traccia successiva in ordine"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="⏮  →  traccia precedente in ordine"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="Traccia Terminata  →  traccia successiva in ordine"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox fx:id="cellCatalogShuffle" spacing="6"
                          GridPane.columnIndex="2" GridPane.rowIndex="1"
                          style="-fx-background-color: #111C22; -fx-padding: 10; -fx-background-radius: 6;">
                        <Label text="⏭  →  traccia casuale dal catalogo"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="⏮  →  traccia precedentemente riprodotta"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="Traccia Terminata  →  traccia casuale dal catalogo"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox fx:id="cellCatalogLoop" spacing="6"
                          GridPane.columnIndex="3" GridPane.rowIndex="1"
                          style="-fx-background-color: #111C22; -fx-padding: 10; -fx-background-radius: 6;">
                        <Label text="⏭  →  stessa traccia"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="⏮  →  stessa traccia"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="Traccia Terminata  →  stessa traccia in loop"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- ── Riga Playlist ── -->
                    <Label text="Playlist"
                           GridPane.columnIndex="0" GridPane.rowIndex="2"
                           style="-fx-text-fill: #8AABAE; -fx-font-weight: bold; -fx-font-size: 12px;"/>

                    <VBox fx:id="cellPlaylistSequential" spacing="6"
                          GridPane.columnIndex="1" GridPane.rowIndex="2"
                          style="-fx-background-color: #111C22; -fx-padding: 10; -fx-background-radius: 6;">
                        <Label text="⏭  →  traccia successiva in ordine"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="⏮  →  traccia precedente (anche in altra playlist)"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="⏭⏭  →  playlist successiva nel catalogo"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="⏮⏮  →  playlist precedente nel catalogo"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="Playlist Terminata  →  playlist successiva"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox fx:id="cellPlaylistShuffle" spacing="6"
                          GridPane.columnIndex="2" GridPane.rowIndex="2"
                          style="-fx-background-color: #111C22; -fx-padding: 10; -fx-background-radius: 6;">
                        <Label text="⏭  →  traccia casuale nella playlist"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="⏮  →  traccia precedentemente riprodotta"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="⏭⏭  →  playlist casuale dal catalogo"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="⏮⏮  →  playlist casuale dal catalogo"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="Playlist Terminata  →  traccia casuale, resta nella playlist"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox fx:id="cellPlaylistLoop" spacing="6"
                          GridPane.columnIndex="3" GridPane.rowIndex="2"
                          style="-fx-background-color: #111C22; -fx-padding: 10; -fx-background-radius: 6;">
                        <Label text="⏭  →  traccia successiva in ordine"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="⏮  →  traccia precedentemente riprodotta"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="⏭⏭  →  playlist corrente riparte da capo"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="⏮⏮  →  playlist corrente riparte da capo"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                        <Label text="Playlist Terminata  →  sequenza in loop sulla playlist"
                               style="-fx-text-fill: #E8EDF0; -fx-font-size: 11px;"/>
                    </VBox>

                </GridPane>
                <Separator style="-fx-background-color: #1B2A2F;">
                    <VBox.margin><Insets top="10" bottom="10"/></VBox.margin>
                </Separator>

                <VBox spacing="6" style="-fx-padding: 0 0 0 0;">
                    <Label text="⏮  Comportamento del pulsante precedente:"
                           style="-fx-text-fill: #1D9E75; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <Label text="• Entro i primi 10 secondi  →  torna alla traccia precedente"
                           style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                    <Label text="• Dopo i 10 secondi  →  la traccia corrente riparte dall'inizio"
                           style="-fx-text-fill: #E8EDF0; -fx-font-size: 12px;"/>
                </VBox>
            </VBox>
        </StackPane>
    </center>

    <!-- ══════════════════════════════════════
         BOTTOM — barra di riproduzione
         ══════════════════════════════════════ -->
    <bottom>
        <fx:include fx:id="playbackBar" source="PlaybackBarView.fxml"/>
    </bottom>

</BorderPane>
