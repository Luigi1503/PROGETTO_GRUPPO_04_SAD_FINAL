<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ContextMenu?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.gruppo04.view.TrackView"
            style="-fx-background-color: #111C22; -fx-font-family: 'Segoe UI', Arial, sans-serif;">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <!-- ── HEADER ── -->
    <top>
        <VBox spacing="4">
            <padding><Insets bottom="16"/></padding>

            <!-- titolo + pulsante -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Catalogo Musicale"
                           style="-fx-text-fill: #E8EDF0; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <Label text="Elenco completo delle tracce audio disponibili"
                           style="-fx-text-fill: #5C7A7D; -fx-font-size: 12px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="addTrackBtn" text="+ Aggiungi brano"
                        style="-fx-background-color: #1D6A72;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-weight: bold;
                           -fx-font-size: 13px;
                           -fx-background-radius: 7;
                           -fx-padding: 8 18 8 18;
                           -fx-cursor: hand;"/>
            </HBox>

            <!-- barra ricerca -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <padding><Insets top="10"/></padding>
                <TextField fx:id="searchField"
                           promptText="Cerca per titolo, artista, genere..."
                           maxWidth="400"
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-color: #1B2A2F;
                           -fx-text-fill: #E8EDF0;
                           -fx-prompt-text-fill: #4A6468;
                           -fx-background-radius: 7;
                           -fx-border-color: #2C3E40;
                           -fx-border-radius: 7;
                           -fx-border-width: 1;
                           -fx-padding: 7 12 7 12;
                           -fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ── TABELLA ── -->
    <center>
        <TableView fx:id="trackTable"
                   style="-fx-background-color: transparent;
                   -fx-table-cell-border-color: transparent;
                   -fx-border-color: transparent;
                   -fx-padding: 0;">

            <columns>
                <TableColumn fx:id="indexCol" text="#"
                             prefWidth="40" minWidth="40" maxWidth="40"
                             sortable="false"
                             style="-fx-alignment: CENTER;"/>

                <TableColumn fx:id="titleCol" text="TITOLO"
                             prefWidth="260"/>

                <TableColumn fx:id="artistCol" text="ARTISTA"
                             prefWidth="180"/>

                <TableColumn fx:id="yearCol" text="ANNO"
                             prefWidth="70"
                             style="-fx-alignment: CENTER_RIGHT;"/>

                <TableColumn fx:id="genreCol" text="GENERE"
                             prefWidth="130"/>

                <TableColumn fx:id="durationCol" text="DURATA"
                             prefWidth="70"
                             style="-fx-alignment: CENTER_RIGHT;"/>

                <TableColumn fx:id="tagsCol" text=""
                             prefWidth="60" minWidth="60" maxWidth="60"
                             sortable="false"
                             style="-fx-alignment: CENTER;"/>

                <TableColumn fx:id="actionsCol" text=""
                             prefWidth="40" minWidth="40" maxWidth="40"
                             sortable="false"
                             style="-fx-alignment: CENTER;"/>
            </columns>

            <!-- context menu -->
            <contextMenu>
                <ContextMenu style="-fx-background-color: #1B2A2F;
                                    -fx-background-radius: 8;
                                    -fx-border-color: #2C3E40;
                                    -fx-border-radius: 8;
                                    -fx-border-width: 1;
                                    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 12, 0, 0, 4);
                                    -fx-padding: 4 0 4 0;">
                    <items>
                        <MenuItem fx:id="menuPlay" text="▶   Riproduci ora"/>
                        <MenuItem fx:id="menuFav"  text="☆   Aggiungi ai preferiti"/>
                        <MenuItem fx:id="menuMove" text="↕   Sposta su / giù"/>
                        <SeparatorMenuItem/>
                        <MenuItem fx:id="menuRemove" text="✕   Rimuovi traccia"
                                  onAction="#onDeleteButtonClicked"
                                  style="-fx-text-fill: #E05555;"/>
                        <MenuItem fx:id="menuEdit" text="✏   Modifica traccia"/>
                    </items>
                </ContextMenu>
            </contextMenu>

            <!-- placeholder tabella vuota -->
            <placeholder>
                <VBox alignment="CENTER" spacing="8">
                    <Label text="Nessuna traccia trovata"
                           style="-fx-text-fill: #3A5258; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label text="Aggiungi il tuo primo brano con il pulsante in alto"
                           style="-fx-text-fill: #2C3E40; -fx-font-size: 12px;"/>
                </VBox>
            </placeholder>
        </TableView>
    </center>

    <!-- ── FOOTER ── -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="12"/></padding>
            <Label fx:id="statusLabel" text="Caricamento tracce..."
                   style="-fx-text-fill: #3A5258; -fx-font-size: 11px; -fx-font-style: italic;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="countLabel" text=""
                   style="-fx-text-fill: #3A5258; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>
